# Copy to `.env.local` for local overrides (never commit secrets).

# Production URL (no trailing slash). Used for sitemap, robots, JSON-LD, canonicals.
# Defaults to http://localhost:3000 when unset.
# NEXT_PUBLIC_SITE_URL=https://www.gavion.in

# --- Transactional email (Resend) — contact & careers forms ---
# https://resend.com — verify a domain for production; trial can use onboarding@resend.dev
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL="Gavion Website <onboarding@resend.dev>"
# CONTACT_TO_EMAIL=info@gavion.in
# CAREERS_TO_EMAIL=careers@gavion.in

# Example: CMS / headless content
# NEXT_PUBLIC_CMS_URL=

# Example: AI (server-only)
# OPENAI_API_KEY=

# Vercel Web Analytics & Speed Insights load automatically on Vercel when enabled in the project dashboard.
